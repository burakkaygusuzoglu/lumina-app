# ─────────────────────────────────────────────
# Lumina Life OS — Backend Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Supabase (get from: https://supabase.com → Project Settings → API)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Anthropic Claude AI (get from: https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: Pinecone for semantic search
PINECONE_API_KEY=
PINECONE_INDEX=lumina-memories

# JWT Security
JWT_SECRET_KEY=lumina-dev-secret-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Vault Encryption (must be exactly 32 bytes in production)
VAULT_ENCRYPTION_KEY=lumina-vault-key-32-bytes-padded!

# App
DEBUG=false
