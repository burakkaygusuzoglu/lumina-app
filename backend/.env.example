# Lumina Life OS - Backend Environment
# Copy to backend/.env and fill in your values

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-api03-xxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# Pinecone Semantic Search
# Create index at app.pinecone.io: name=lumina-memories, metric=cosine, dims=1024, type=serverless
PINECONE_API_KEY=pcsk_xxx
PINECONE_INDEX=lumina-memories

# JWT
JWT_SECRET_KEY=generate-a-64-char-random-hex
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Vault AES-256 key
VAULT_ENCRYPTION_KEY=generate-a-64-char-hex

DEBUG=false
